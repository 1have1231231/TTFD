# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ttfd_db?schema=public"

# Discord OAuth2
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_REDIRECT_URI="http://localhost:3000/api/auth/discord/callback"
DISCORD_GUILD_ID="your_discord_guild_id"

# Discord Bot
DISCORD_BOT_TOKEN="your_discord_bot_token"

# Session/JWT
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"
SESSION_SECRET="your_session_secret_change_this"

# Admin Discord IDs (comma-separated)
ADMIN_DISCORD_IDS="123456789012345678,987654321098765432"

# Roulette Config
ROULETTE_MIN_BET="10"
ROULETTE_MAX_BET="100000"
ROULETTE_WIN_CHANCE="0.47"
ROULETTE_WIN_MULTIPLIER="2"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
