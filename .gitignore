.env
.env.*
!.env.example
*.env
.env.local
.env.production
.env.development

# ═══════════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual Environment
venv/
env/
ENV/
.venv/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ═══════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3
*.json
!package.json
!tsconfig.json
!.env.example
!railway.json

# Данные пользователей
accounts.json
user_data.json
history.json

# ═══════════════════════════════════════════════════════════════
